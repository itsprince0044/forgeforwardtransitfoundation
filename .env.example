# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Email transport: choose ONE ──────────────────────────────────────────────

# Option A (recommended for now): Gmail SMTP — sends from your Gmail to ANY
# recipient with no domain needed. Requires 2-Step Verification on the account
# and an "App Password" (https://myaccount.google.com/apppasswords).
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Option B: Resend — https://resend.com
# Until RESEND_API_KEY is set, emails are skipped (app still works).
RESEND_API_KEY=your_resend_api_key_here
# Verified sender. For testing you can use the Resend sandbox address below.
RESEND_FROM="Forge Forward Transit Foundation <onboarding@resend.dev>"
# Replies to notification emails go here.
REPLY_TO=coordinator@example.com
# Who gets the "new ride request" alert (comma-separated). Falls back to the
# coordinator profiles in the database if left blank.
COORDINATOR_EMAILS=coordinator@example.com
# Base URL used to build the email "Accept" button link (your deployed site URL).
APP_URL=http://localhost:3030

# SMS notifications (Twilio) — https://twilio.com
# Until all three are set, SMS is skipped (app still works).
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
